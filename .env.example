# Google AdSense — get slot from AdSense → Ads → By ad unit → Display (or Responsive) unit
# Client defaults to ca-pub-8542326322762354 in code if unset.
VITE_ADSENSE_CLIENT_ID=ca-pub-8542326322762354
VITE_ADSENSE_AD_SLOT=

# Local dev: real ads often do not appear on http://localhost (Google policy).
# The app sets data-adtest=on in DEV. Confirm on https://your-domain/ after deploy.
